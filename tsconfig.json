{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "esnext",
    "module": "esnext",
    "rootDir": "./webserver/src",
    "outDir": "./webserver/dist",
    "strict": true,
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["./webserver/src/**/*.ts"],
  "exclude": ["node_modules"]
}